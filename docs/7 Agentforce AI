## Apex Trigger — ApplicationTrigger.trigger

```apex
trigger ApplicationTrigger on Application__c (after insert) {
    List<Application__c> toUpdate = new List<Application__c>();
    Set<Id> candidateIds = new Set<Id>();
    Set<Id> jobIds = new Set<Id>();

    for (Application__c app : Trigger.new) {
        candidateIds.add(app.Candidate__c);
        jobIds.add(app.Job__c);
    }

    Map<Id, Candidate__c> candidates = new Map<Id, Candidate__c>(
        [SELECT Id, Skills__c, Experience_Years__c FROM Candidate__c WHERE Id IN :candidateIds]
    );
    Map<Id, Job__c> jobs = new Map<Id, Job__c>(
        [SELECT Id, Required_Skills__c, Job_Description__c FROM Job__c WHERE Id IN :jobIds]
    );

    for (Application__c app : Trigger.new) {
        Candidate__c c = candidates.get(app.Candidate__c);
        Job__c j = jobs.get(app.Job__c);

        AICandidateMatcher.MatchRequest req = new AICandidateMatcher.MatchRequest();
        req.candidateSkills = c.Skills__c;
        req.candidateExperience = (Integer) c.Experience_Years__c;
        req.jobRequiredSkills = j.Required_Skills__c;
        req.jobDescription = j.Job_Description__c;

        List<AICandidateMatcher.MatchResult> results = AICandidateMatcher.calculateScore(
            new List<AICandidateMatcher.MatchRequest>{ req }
        );

        Application__c updateApp = new Application__c(Id = app.Id);
        updateApp.AI_Recommendation__c = results[0].recommendation;
        toUpdate.add(updateApp);
    }

    if (!toUpdate.isEmpty()) {
        update toUpdate;
    }
}
```

