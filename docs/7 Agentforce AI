## Apex Class — AgentforceService.cls (HTTP wrapper)

```apex
public with sharing class AgentforceService {

    private static final String AGENT_ENDPOINT = 'callout:Agentforce_API/agents/invoke';

    public static String callAgent(String agentName, String prompt) {
        HttpRequest req = new HttpRequest();
        req.setEndpoint(AGENT_ENDPOINT);
        req.setMethod('POST');
        req.setHeader('Content-Type', 'application/json');
        req.setBody(JSON.serialize(new Map<String, Object>{
            'agent' => agentName,
            'input' => prompt
        }));
        Http http = new Http();
        HttpResponse res = http.send(req);
        if (res.getStatusCode() == 200) {
            return res.getBody();
        }
        throw new CalloutException('Agentforce call failed: ' + res.getStatus());
    }
}
```

