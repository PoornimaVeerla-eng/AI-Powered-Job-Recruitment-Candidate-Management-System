## Apex Class — AICandidateMatcher.cls

```apex
public with sharing class AICandidateMatcher {

    @InvocableMethod(label='Calculate AI Match Score' description='Calls Agentforce/Einstein to score candidate vs job')
    public static List<MatchResult> calculateScore(List<MatchRequest> requests) {
        List<MatchResult> results = new List<MatchResult>();
        for (MatchRequest req : requests) {
            MatchResult res = new MatchResult();
            try {
                String prompt = buildPrompt(req);
                String response = AgentforceService.callAgent('RecruitmentAgent', prompt);
                Map<String, Object> parsed = (Map<String, Object>) JSON.deserializeUntyped(response);
                res.matchScore = (Integer) parsed.get('match_score');
                res.recommendation = (String) parsed.get('recommendation');
            } catch (Exception e) {
                res.matchScore = 0;
                res.recommendation = 'Error: ' + e.getMessage();
            }
            results.add(res);
        }
        return results;
    }

    private static String buildPrompt(MatchRequest req) {
        return 'Candidate Skills: ' + req.candidateSkills +
               '\nCandidate Experience: ' + req.candidateExperience +
               '\nJob Required Skills: ' + req.jobRequiredSkills +
               '\nJob Description: ' + req.jobDescription;
    }

    public class MatchRequest {
        @InvocableVariable(required=true) public String candidateSkills;
        @InvocableVariable(required=true) public Integer candidateExperience;
        @InvocableVariable(required=true) public String jobRequiredSkills;
        @InvocableVariable public String jobDescription;
    }

    public class MatchResult {
        @InvocableVariable public Integer matchScore;
        @InvocableVariable public String recommendation;
    }
}
```

