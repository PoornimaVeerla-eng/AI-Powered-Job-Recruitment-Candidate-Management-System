        <name>ValidationRule</name>
    </types>
    <types>
        <members>Offer_Approval_Process</members>
        <name>ApprovalProcess</name>
    </types>
    <types>
        <members>*</members>
        <name>Flow</name>
    </types>
    <types>
        <members>AICandidateMatcher</members>
        <members>AgentforceService</members>
        <members>AICandidateMatcherTest</members>
        <name>ApexClass</name>
    </types>
    <types>
        <members>ApplicationTrigger</members>
        <name>ApexTrigger</name>
    </types>
    <types>
        <members>candidateMatchCard</members>
        <name>LightningComponentBundle</name>
    </types>
    <types>
        <members>Recruitment_Hub</members>
        <name>CustomApplication</name>
    </types>
    <types>
        <members>Recruiter</members>
        <members>HR_Manager</members>
        <members>Interviewer</members>
        <name>Profile</name>
    </types>
    <version>59.0</version>
</Package>
```

---

## Deployment Commands

### Step 1 — Authorize Production Org
```bash
sfdx auth:web:login -a Prod -r https://login.salesforce.com
```

### Step 2 — Validate Deployment (Quick Deploy Check)
```bash
sfdx force:source:deploy -x manifest/package.xml -u Prod -l RunLocalTests -c
```

### Step 3 — Deploy to Production
```bash
sfdx force:source:deploy -x manifest/package.xml -u Prod -l RunLocalTests
```

### Step 4 — Run Apex Tests
```bash
sfdx force:apex:test:run -u Prod -c -r human -w 10
```

---

## CI/CD — GitHub Actions

### .github/workflows/sfdx-deploy.yml
```yaml
name: Salesforce Deploy

on:
  push:
    branches: [ main ]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Install Salesforce CLI
        run: npm install -g @salesforce/cli

      - name: Authenticate to Salesforce
        run: |
          echo ${{ secrets.SFDX_AUTH_URL }} > authfile.txt
          sf org login sfdx-url -f authfile.txt -a Prod

      - name: Deploy Metadata
        run: sf project deploy start -x manifest/package.xml -o Prod -l RunLocalTests

      - name: Run Tests
        run: sf apex run test -o Prod -c -r human -w 10
```

---

## Pre-Deployment Checklist

- [ ] All Apex tests pass with ≥ 75% code coverage
- [ ] Validation rules tested in Sandbox
- [ ] Approval process tested with sample data
- [ ] Profiles & Permission Sets reviewed
- [ ] Duplicate Rules tested
- [ ] Email templates previewed
- [ ] Agentforce agent activated in target org
- [ ] Data backup created

---

## Post-Deployment Tasks

1. Activate Approval Process in target org.
2. Assign Permission Sets to users.
3. Verify Agentforce agent status.
4. Import seed data (sample Jobs & Candidates).
5. Train end-users via documentation.




