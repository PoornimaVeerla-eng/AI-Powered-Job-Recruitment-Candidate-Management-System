## Lightning Web Component — candidateMatchCard

### candidateMatchCard.html
```html
<template>
    <lightning-card title=\"AI Match Analysis\" icon-name=\"custom:custom63\">
        <div class=\"slds-p-around_medium\">
            <p><strong>Match Score:</strong> 
                <lightning-badge label={matchScore} class={badgeVariant}></lightning-badge>
            </p>
            <p class=\"slds-m-top_small\"><strong>Recommendation:</strong></p>
            <p>{recommendation}</p>
            <lightning-button 
                variant=\"brand\" 
                label=\"Re-run AI Analysis\" 
                onclick={runAnalysis}
                class=\"slds-m-top_medium\">
            </lightning-button>
        </div>
    </lightning-card>
</template>
```

### candidateMatchCard.js
```javascript
import { LightningElement, api, wire } from 'lwc';
import { getRecord } from 'lightning/uiRecordApi';
import runAIMatch from '@salesforce/apex/AICandidateMatcher.calculateScore';

const FIELDS = [
    'Application__c.AI_Recommendation__c',
    'Application__c.Candidate__r.AI_Match_Score__c'
];

export default class CandidateMatchCard extends LightningElement {
    @api recordId;
    matchScore = 0;
    recommendation = '';

    @wire(getRecord, { recordId: '$recordId', fields: FIELDS })
    wiredRecord({ data }) {
        if (data) {
            this.matchScore = data.fields.Candidate__r.value.fields.AI_Match_Score__c.value;
            this.recommendation = data.fields.AI_Recommendation__c.value;
        }
    }

    get badgeVariant() {
        if (this.matchScore >= 75) return 'slds-theme_success';
        if (this.matchScore >= 50) return 'slds-theme_warning';
        return 'slds-theme_error';
    }

    runAnalysis() {
        runAIMatch({ /* params */ })
            .then(result => {
                this.matchScore = result[0].matchScore;
                this.recommendation = result[0].recommendation;
            });
    }
}
```

